# Set this after deployment.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# localnet, simulator, studionet, testnetAsimov, testnetBradbury
NEXT_PUBLIC_GENLAYER_CHAIN=localnet

# Default local Studio/GLSim endpoint. Some chain presets ignore this value.
NEXT_PUBLIC_GENLAYER_RPC_URL=http://localhost:4000/api

# true lets the UI run a browser-only demo when no contract is deployed.
NEXT_PUBLIC_DEMO_MODE=true
